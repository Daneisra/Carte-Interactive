# Normaliser les fins de ligne
* text=auto

# Traiter ces fichiers comme texte (diff corrects)
*.html text
*.css  text
*.js   text
*.json text
*.md   text
*.py   text

# Git LFS pour les binaires lourds audio
*.mp3 filter=lfs diff=lfs merge=lfs -text
*.wav filter=lfs diff=lfs merge=lfs -text
assets/map.png filter=lfs diff=lfs merge=lfs -text
